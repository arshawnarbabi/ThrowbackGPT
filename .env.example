# Copy this file to .env.local and fill in your key.
# Without a key, the app runs in MOCK mode (canned, era-flavored replies) so the
# full UI is still usable.

# Your OpenAI API key (server-side only — do NOT prefix with NEXT_PUBLIC_).
OPENAI_API_KEY=

# Optional — the chat model. Defaults to gpt-4o-mini if unset.
OPENAI_MODEL=gpt-4o-mini
